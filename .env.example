# =============================================================================
# Rare Disease Diagnostic Agent - Environment Configuration
# Copy this file to .env and set your values
# =============================================================================

# -- Anthropic API Key (required for LLM features) --
ANTHROPIC_API_KEY=sk-ant-your-key-here

# -- Milvus Vector Database --
RD_MILVUS_HOST=localhost
RD_MILVUS_PORT=19530

# -- Service Ports --
RD_API_PORT=8134
RD_STREAMLIT_PORT=8544

# -- Embeddings --
RD_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# -- LLM --
RD_LLM_MODEL=claude-sonnet-4-6

# -- RAG Search --
RD_SCORE_THRESHOLD=0.4

# -- Authentication (empty = no auth required) --
RD_API_KEY=

# -- CORS --
RD_CORS_ORIGINS=http://localhost:8080,http://localhost:8134,http://localhost:8544

# -- Scheduled Ingest (Orphanet, OMIM) --
RD_INGEST_ENABLED=false
RD_INGEST_SCHEDULE_HOURS=24

# -- External APIs (optional) --
RD_ORPHANET_API_KEY=
RD_NCBI_API_KEY=

# -- Prometheus Metrics --
RD_METRICS_ENABLED=true

# -- Request Limits --
RD_MAX_REQUEST_SIZE_MB=10
